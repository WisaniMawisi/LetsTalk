<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <de.hdodenhof.circleimageview.CircleImageView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:id="@+id/msgProImg"
        android:layout_marginRight="5dp"

        android:layout_marginTop="10dp"
        android:src="@drawable/baseline_person_24"
        />
    <TextView
        android:id="@+id/receiver_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="10dp"
        android:layout_toEndOf="@id/msgProImg"
        android:background="@drawable/receiver_message_layout"
        android:padding="10dp"
        android:text="receiver message here"
        android:textColor="#fff"
        android:textSize="16dp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/Sender_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:background="@drawable/sender_message_layout"
        android:layout_alignParentTop="@+id/receiver_msg"
        android:padding="10dp"
        android:text="sender message here"
        android:textColor="#000"
        android:textSize="16dp"
        android:textStyle="bold"/>

    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_alignParentEnd="true"
        android:layout_margin="5dp"
        android:scaleType="centerCrop"
        android:id="@+id/imgSender"/>

    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_alignParentStart="true"
        android:layout_margin="5dp"
        android:scaleType="centerCrop"
        android:id="@+id/imgReceiver"/>


</RelativeLayout>